<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="SVGLClubConfigHelper.Pages.EntryListEditorContent"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:SVGLClubConfigHelper.Pages"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:SVGLClubConfigHelper.Models"
    mc:Ignorable="d">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Title Row -->
        <TextBlock 
        Grid.Row="0"
        Text="Entry List Editor"
        Style="{StaticResource SVGLPageTitleStyle}"/>

        <!-- Loading Error/Warning Row -->
        <Grid
            Visibility="{x:Bind ViewModel.CarListLoadingError, Mode=OneWay}"
            Grid.Row="1"
            Margin="20">

            <InfoBar
                IsOpen="{x:Bind ViewModel.CarListLoadingError, Mode=OneWay}" 
                Severity="Error"
                Title="Error"
                Message="Cannot load content folder, view settings to set correct directory and load content."/>
            
        </Grid>
        
        <!-- Content Row -->
        <Grid
            Grid.Row="1"
            Margin="20">

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="0.4*" />
                    <ColumnDefinition Width="0.6*" />
                </Grid.ColumnDefinitions>

                <!-- Car Selection Column -->
                <Grid
                    Grid.Column="0"
                    Margin="6">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBox
                        Grid.Row="0"
                        PlaceholderText="Search"
                        Margin="0, 0, 0, 6"
                        Text="{x:Bind ViewModel.CarSearchBar, Mode=TwoWay}" />

                    <ListView
                        Grid.Row="1"
                        x:Name="CarListView"
                        ItemsSource="{x:Bind ViewModel.CarList, Mode=OneWay}"
                        BorderThickness="1"
                        CanDragItems="True"
                        DragItemsStarting="CarListView_DragItemsStarting"
                        BorderBrush="{ThemeResource ControlStrongStrokeColorDefaultBrush}" >

                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="models:Car">
                                <Grid
                                    Margin="12">

                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="0.1*" />
                                        <ColumnDefinition Width="0.9*" />
                                    </Grid.ColumnDefinitions>

                                    <Image
                                        Grid.Column="0"
                                        Source="{x:Bind BadgeImagePath, Mode=OneWay}"
                                        MaxHeight="30" 
                                        Margin="0, 0, 12, 0" />

                                    <TextBlock
                                        Grid.Column="1"
                                        FontWeight="Bold"
                                        Style="{StaticResource BodyLargeTextBlockStyle}"
                                        Text="{x:Bind Name, Mode=OneWay}" />

                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            
                <!-- Car Entry List Column -->
                <Grid 
                    Grid.Column="1"
                    Margin="6">

                    <Grid.RowDefinitions>
                        <RowDefinition Height="0.5*" />
                        <RowDefinition Height="0.5*" />
                    </Grid.RowDefinitions>

                    <ListView
                        Grid.Row="0"
                        x:Name="CarEntryListView"
                        ItemsSource="{x:Bind ViewModel.EntryList, Mode=TwoWay}"
                        SelectedItem="{x:Bind ViewModel.SelectedCarEntry, Mode=TwoWay}"
                        BorderThickness="1"
                        AllowDrop="True"
                        DragOver="CarEntryListView_DragOver"
                        Drop="CarEntryListView_Drop"
                        BorderBrush="{ThemeResource ControlStrongStrokeColorDefaultBrush}" >

                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="models:CarEntry">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <Grid
                                        Grid.Column="0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="0.5*" />
                                            <ColumnDefinition Width="0.5*" />
                                        </Grid.ColumnDefinitions>

                                        <TextBlock
                                            Grid.Column="0"
                                            Text="{x:Bind Car.Name}" 
                                            VerticalAlignment="Center"/>

                                        <ComboBox
                                            Grid.Column="1"
                                            Width="250"
                                            ItemsSource="{x:Bind Car.Skins}"
                                            DisplayMemberPath="SkinId"
                                            Loaded="CarEntryComboBox_OnLoaded"
                                            SelectionChanged="CarEntryComboBox_SelectionChanged" />

                                        <StackPanel
                                            Grid.Column="2"
                                            Spacing="6"
                                            Orientation="Horizontal" >

                                            <TextBlock
                                                VerticalAlignment="Center"
                                                Text="Ballast: " />
                                            <TextBox
                                                InputScope="Number"
                                                Loaded="BallastTextBox_OnLoaded"
                                                TextChanged="BallastTextBox_OnTextChanged"/>
                                        </StackPanel>
                                        
                                        <StackPanel
                                            Grid.Column="3"
                                            Spacing="6"
                                            Orientation="Horizontal" >

                                            <TextBlock
                                                VerticalAlignment="Center"
                                                Text="Restrictor: " />
                                            <TextBox
                                                InputScope="Number"
                                                Loaded="RestrictorTextBox_OnLoaded"
                                                TextChanged="RestrictorTextBox_OnTextChanged"/>
                                        </StackPanel>

                                    </Grid>

                                    <Button
                                        Grid.Column="1"
                                        HorizontalContentAlignment="Right"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        ToolTipService.ToolTip="Delete"
                                        Command="{Binding DataContext.DeleteCarEntryCommand, ElementName=CarEntryListView}"
                                        CommandParameter="{Binding}">

                                        <FontIcon
                                            FontFamily="Segoe Fluent Icons"
                                            Glyph="&#xE74D;" />
                                    </Button>
                                </Grid>

                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>

                    <Grid
                        Grid.Row="1">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBox
                            Grid.Row="0"
                            Margin="0, 6, 0, 6"
                            AcceptsReturn="True"
                            TextWrapping="Wrap"
                            Text="{x:Bind ViewModel.EntryListString, Mode=OneWay}"
                            IsReadOnly="True" />

                        <Grid
                            Grid.Row="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <TextBox
                                Grid.Column="0"
                                Margin="0, 6, 6, 6"
                                Text="{x:Bind ViewModel.CarSelectionString, Mode=OneWay}"
                                IsReadOnly="True" />

                            <StackPanel
                                Grid.Column="1"
                                Orientation="Horizontal"
                                Spacing="6"
                                HorizontalAlignment="Right" >

                                <Button
                                    HorizontalAlignment="Right"
                                    Content="Copy Car Selection"
                                    Command="{x:Bind ViewModel.CopyCarSelectionCommand}"/>
                                <Button
                                    HorizontalAlignment="Right"
                                    Content="Copy Entry List"
                                    Command="{x:Bind ViewModel.CopyEntryListCommand}"/>
                            </StackPanel>
                        </Grid>
                        
                    </Grid>
                </Grid>

            </Grid>
            
        </Grid>
    </Grid>
</Page>
