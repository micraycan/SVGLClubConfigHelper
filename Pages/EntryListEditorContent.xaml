<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="SVGLClubConfigHelper.Pages.EntryListEditorContent"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:SVGLClubConfigHelper.Pages"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:SVGLClubConfigHelper.Models"
    mc:Ignorable="d">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Title Row -->
        <TextBlock 
        Grid.Row="0"
        Text="Entry List Editor"
        Style="{StaticResource SVGLPageTitleStyle}"/>

        <!-- Progress Bar Row -->
        <Grid
            Visibility="{x:Bind ViewModel.ProgressBarVisible, Mode=OneWay}"
            Grid.Row="1"
            Margin="20">

            <StackPanel>
                <ProgressBar
                    IsIndeterminate="True"
                    ShowPaused="False"
                    ShowError="{x:Bind ViewModel.CarListLoadingError, Mode=OneWay}"
                    HorizontalAlignment="Stretch" 
                    VerticalAlignment="Center" />

                <InfoBar
                    IsOpen="{x:Bind ViewModel.CarListLoadingError, Mode=OneWay}" 
                    Severity="Error"
                    Title="Error"
                    Message="Cannot load content folder, make sure content folder is set in Settings to the correct directory."/>
            </StackPanel>
            
        </Grid>
        
        <!-- Content Row -->
        <Grid
            Visibility="{x:Bind ViewModel.CarListVisible, Mode=OneWay}"
            Grid.Row="1"
            Margin="20">

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="0.5*" />
                    <ColumnDefinition Width="0.5*" />
                </Grid.ColumnDefinitions>

                <!-- Car List Column -->
                <Grid
                    Grid.Column="0"
                    Margin="0, 0, 6, 0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    
                    <TextBox 
                        Grid.Row="0"
                        PlaceholderText="Search"
                        Margin="0, 0, 0, 6"
                        Text="{x:Bind ViewModel.CarListSearchBar, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                    <ListView
                        Background="{StaticResource SolidBackgroundFillColorBaseBrush}"
                        Grid.Row="1"
                        x:Name="CarListView"
                        SelectionMode="Single"
                        SelectedItem="{x:Bind ViewModel.SelectedCar, Mode=TwoWay}"
                        ItemsSource="{x:Bind ViewModel.CarList, Mode=OneWay}">

                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="models:Car">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <Image
                                        MaxHeight="20"
                                        Source="{x:Bind BadgeImagePath}"
                                        Grid.Column="0" />

                                    <TextBlock
                                        Grid.Column="1"
                                        Text="{x:Bind Name}"
                                        Margin="12, 0, 0, 0"
                                        Style="{StaticResource BodyLargeStrongTextBlockStyle}" />
                                    
                                </Grid>

                            </DataTemplate>
                        </ListView.ItemTemplate>

                    </ListView>
                </Grid>
            
                <!-- Car selection column -->
                <Grid
                    Grid.Column="1"
                    Margin="6, 0, 0, 0"
                    Visibility="{x:Bind ViewModel.IsCarSelected, Mode=OneWay}">

                    <Grid.RowDefinitions>
                        <RowDefinition Height="0.5*" />
                        <RowDefinition Height="0.5*" />
                    </Grid.RowDefinitions>
                    
                    <!-- Skin selection/preview -->
                    <Grid
                        Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="0.5*" />
                            <ColumnDefinition Width="0.5*" />
                        </Grid.ColumnDefinitions>

                        <ListView
                            Background="{StaticResource SolidBackgroundFillColorBaseBrush}"
                            Grid.Column="0"
                            x:Name="SkinListView"
                            SelectionMode="Single"
                            SelectedItem="{x:Bind ViewModel.SelectedSkin, Mode=TwoWay}"
                            ItemsSource="{x:Bind ViewModel.AvailableSkins, Mode=OneWay}" >

                            <ListView.ItemTemplate>
                                <DataTemplate x:DataType="models:Skin">
                                    <TextBlock
                                       Text="{x:Bind SkinId}" />
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>

                        <Grid
                            Grid.Column="1"
                            Margin="6, 0, 0, 0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="0.5*" />
                                <RowDefinition Height="0.25*" />
                                <RowDefinition Height="0.25*" />
                            </Grid.RowDefinitions>
                            
                            <Image
                                Grid.Row="0"
                                Source="{x:Bind ViewModel.SkinPreview, Mode=OneWay}"/>

                            <Grid
                                Grid.Row="1"
                                Margin="0, 6, 0, 0">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="0.1*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <TextBlock
                                        Grid.Row="0"
                                        Grid.Column="0"
                                        Text="BHP: "
                                        FontWeight="SemiBold" />

                                    <TextBlock
                                        Grid.Row="0"
                                        Grid.Column="1"
                                        Margin="6, 0, 0, 0"
                                        Text="{x:Bind ViewModel.SelectedCar.Specs.BHP, Mode=OneWay}" />

                                    <TextBlock
                                        Grid.Row="1"
                                        Grid.Column="0"
                                        Text="Torque: "
                                        FontWeight="SemiBold" />

                                    <TextBlock
                                        Grid.Row="1"
                                        Grid.Column="1"
                                        Margin="6, 0, 0, 0"
                                        Text="{x:Bind ViewModel.SelectedCar.Specs.Torque, Mode=OneWay}" />

                                    <TextBlock
                                        Grid.Row="2"
                                        Grid.Column="0"
                                        Text="Weight: "
                                        FontWeight="SemiBold" />

                                    <TextBlock
                                        Grid.Row="2"
                                        Grid.Column="1"
                                        Margin="6, 0, 0, 0"
                                        Text="{x:Bind ViewModel.SelectedCar.Specs.Weight, Mode=OneWay}" />

                                    <TextBlock
                                        Grid.Row="3"
                                        Grid.Column="0"
                                        Text="P/W Ratio: "
                                        FontWeight="SemiBold" />

                                    <TextBlock
                                        Grid.Row="3"
                                        Grid.Column="1"
                                        Margin="6, 0, 0, 0"
                                        Text="{x:Bind ViewModel.SelectedCar.Specs.PWRatio, Mode=OneWay}" />
                                </Grid>
                            </Grid>

                            <Grid
                                Grid.Row="2" >
                                <Button
                                    VerticalAlignment="Bottom"
                                    HorizontalAlignment="Right"
                                    Content="Add Car" />
                            </Grid>
                        </Grid>
                        
                    </Grid>
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</Page>
